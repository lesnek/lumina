# TMDB API key (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key

# Groq Cloud API key (https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key

# Aria2 JSON-RPC
ARIA2_RPC_URL=http://aria2:6800/jsonrpc
ARIA2_RPC_SECRET=your_aria2_secret

# Plex download target directory (inside container)
PLEX_MEDIA_DIR=/downloads/plex

# qBittorrent (for torrent downloads via Jackett sources)
QBITTORRENT_URL=http://qbittorrent:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin
